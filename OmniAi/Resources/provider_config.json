{
  "providers": [
    {
      "id": "openai",
      "name": "OpenAI",
      "category": "openai",
      "defaultBaseURL": "https://api.openai.com/v1",
      "urlNormalization": { "appendVersion": true, "versionPath": "/v1" },
      "reasoning": { "strategy": "openai-standard" }
    },
    {
      "id": "deepseek",
      "name": "DeepSeek",
      "category": "openai",
      "defaultBaseURL": "https://api.deepseek.com",
      "urlNormalization": { "appendVersion": false, "versionPath": "" },
      "reasoning": { "strategy": "deepseek-hybrid" },
      "supportedEndpointTypes": ["openai", "anthropic"],
      "defaultEndpointType": "openai",
      "endpointURLs": {
        "openai": "https://api.deepseek.com",
        "anthropic": "https://api.deepseek.com/anthropic"
      }
    },
    {
      "id": "anthropic",
      "name": "Anthropic",
      "category": "anthropic",
      "defaultBaseURL": "https://api.anthropic.com/v1",
      "urlNormalization": { "appendVersion": true, "versionPath": "/v1" },
      "reasoning": { "strategy": "anthropic-thinking" },
      "supportedEndpointTypes": ["openai", "anthropic"],
      "defaultEndpointType": "anthropic",
      "protocol": {
        "request": {
          "stream": true,
          "streamOptions": null,
          "temperatureRange": { "min": 0.0, "max": 1.0 },
          "extraFields": { "max_tokens": 4096 }
        },
        "response": {
          "streamLinePrefix": "data: ",
          "terminationSignal": null,
          "terminationFallback": "message_stop",
          "thinkingFields": ["thinking"],
          "contentField": "text"
        },
        "messageAssembly": {
          "preserveAssistantContentWhenToolCalls": true,
          "includeReasoningContent": false,
          "systemMessageHandling": "separate_parameter"
        }
      }
    },
    {
      "id": "gemini",
      "name": "Google Gemini",
      "category": "gemini",
      "defaultBaseURL": "https://generativelanguage.googleapis.com/v1beta",
      "urlNormalization": { "appendVersion": false, "versionPath": "" },
      "reasoning": { "strategy": "gemini-hybrid" }
    },
    {
      "id": "openrouter",
      "name": "OpenRouter",
      "category": "openai",
      "defaultBaseURL": "https://openrouter.ai/api/v1",
      "urlNormalization": { "appendVersion": true, "versionPath": "/v1" },
      "reasoning": { "strategy": "openai-standard" }
    },
    {
      "id": "minimax",
      "name": "MiniMax",
      "category": "openai",
      "defaultBaseURL": "https://api.minimaxi.com/v1",
      "urlNormalization": { "appendVersion": true, "versionPath": "/v1" },
      "reasoning": { "strategy": "openai-standard" },
      "protocol": {
        "request": {
          "streamOptions": null,
          "extraFields": { "reasoning_split": true }
        },
        "response": {
          "terminationSignal": null,
          "terminationFallback": "finishReason"
        }
      }
    },
    {
      "id": "zhipu",
      "name": "Zhipu",
      "category": "openai",
      "defaultBaseURL": "https://open.bigmodel.cn/api/paas/v4",
      "urlNormalization": { "appendVersion": false, "versionPath": "" },
      "reasoning": { "strategy": "openai-standard" }
    },
    {
      "id": "zai",
      "name": "Z.AI",
      "category": "openai",
      "defaultBaseURL": "https://api.z.ai/api/paas/v4",
      "urlNormalization": { "appendVersion": false, "versionPath": "" },
      "reasoning": { "strategy": "openai-standard" }
    }
  ],
  "reasoningStrategies": {
    "openai-standard": {
      "enableParams": ["reasoning_effort"],
      "disableAction": "reasoning_effort_none"
    },
    "anthropic-thinking": {
      "enableParams": ["thinking"],
      "disableAction": "thinking_disabled",
      "supportsBudget": true,
      "budgetField": "budget_tokens"
    },
    "gemini-hybrid": {
      "enableParams": ["reasoning_effort", "thinking_budget"],
      "disableAction": "reasoning_effort_none"
    },
    "deepseek-hybrid": {
      "enableParams": ["reasoning_effort", "thinking", "enable_thinking"],
      "disableAction": "thinking_disabled",
      "supportsBudget": true,
      "budgetField": "budget_tokens"
    }
  },
  "protocolDefaults": {
    "request": {
      "stream": true,
      "streamOptions": { "include_usage": true },
      "temperatureRange": { "min": 0.0, "max": 2.0 }
    },
    "response": {
      "streamLinePrefix": "data: ",
      "terminationSignal": "[DONE]",
      "terminationFallback": "finishReason",
      "thinkingFields": ["reasoning_content", "thinking"],
      "contentField": "content",
      "toolCallsField": "tool_calls",
      "inlineThinkingTags": [
        { "open": "<think>", "close": "</think>" },
        { "open": "<thought>", "close": "</thought>" }
      ]
    },
    "messageAssembly": {
      "preserveAssistantContentWhenToolCalls": true,
      "includeReasoningContent": true,
      "reasoningFieldName": "reasoning_content"
    }
  }
}
